{
  "name": "jibber-backend",
  "description": "Parse-server for Jibber app",
  "engines": {
    "node": ">=22.13.0 <23",
    "npm": ">=10 <12"
  },
  "scripts": {
    "build": "npm run clean && babel -d ./dist ./src -s",
    "clean": "rm -rf dist && mkdir dist",
    "dev:dist": "npm run build && nodemon ./dist/index.js",
    "dev:src": "babel-node src",
    "dev:watch": "nodemon --watch 'src/**/*' -e js,json --exec 'npm run dev:src'",
    "heroku-prebuild": "echo $IOS_APN_KEY_BASE64 | base64 --decode > $IOS_APN_KEY",
    "heroku-postbuild": "npm run build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prettier": "prettier",
    "start": "node ./dist/index.js",
    "test": "node scripts/run-tests.js"
  },
  "dependencies": {
    "@parse/push-adapter": "8.5.0",
    "@parse/s3-files-adapter": "5.3.1",
    "axios": "1.18.1",
    "dotenv": "17.4.2",
    "express": "4.22.2",
    "extendable-error-class": "^0.1.2",
    "google-libphonenumber": "3.2.44",
    "hat": "0.0.3",
    "mongoose": "8.24.1",
    "parse": "8.6.0",
    "parse-server": "9.9.0",
    "tcp-port-used": "1.0.3",
    "uuid": "11.1.1",
    "validator": "13.15.35"
  },
  "devDependencies": {
    "@babel/cli": "7.29.7",
    "@babel/core": "7.29.7",
    "@babel/node": "7.29.7",
    "@babel/plugin-transform-class-properties": "7.29.7",
    "@babel/plugin-transform-strict-mode": "7.29.7",
    "@babel/preset-env": "7.29.7",
    "@babel/register": "7.29.7",
    "babel-jest": "30.2.0",
    "babel-plugin-inline-json-import": "^0.3.2",
    "eslint": "8.57.1",
    "eslint-config-airbnb-base": "15.0.0",
    "eslint-config-prettier": "9.1.2",
    "eslint-plugin-import": "2.32.0",
    "faker": "^4.1.0",
    "husky": "^7.0.4",
    "jest": "30.2.0",
    "jest-dev-server": "11.0.0",
    "mongodb-runner": "6.8.2",
    "nodemon": "3.1.14",
    "prettier": "^2.0.5"
  }
}
